---
interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'Anika Craney',
	description = 'Freediving experiences shaped by ocean connection, breathwork, and mindful confidence.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<link rel="icon" type="image/png" href="/favicon.png" />
		<link rel="alternate icon" href="/favicon.ico" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700&family=Cormorant+Garamond:wght@500;600;700&display=swap"
			rel="stylesheet"
		/>
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>

<style is:global>
	:root {
		--bg: #f4efe7;
		--surface: #faf7f0;
		--text: #10222d;
		--muted: #50616a;
		--border: rgba(16, 34, 45, 0.12);
		--accent: #9ed5d6;
		--accent-soft: #cde8df;
		--accent-deep: #195566;
		--font-body: 'Manrope', sans-serif;
		--font-display: 'Cormorant Garamond', serif;
	}

	* {
		box-sizing: border-box;
	}

	html {
		scroll-behavior: smooth;
	}

	body {
		margin: 0;
		min-width: 320px;
		color: var(--text);
		font-family: var(--font-body);
		background:
			radial-gradient(circle at top, rgba(158, 213, 214, 0.45), transparent 32%),
			radial-gradient(circle at right 20%, rgba(25, 85, 102, 0.12), transparent 22%),
			linear-gradient(180deg, #f8f4ec 0%, var(--bg) 100%);
	}

	img {
		max-width: 100%;
	}

	a,
	button {
		font: inherit;
	}

	p {
		color: var(--muted);
	}

	strong {
		color: var(--text);
	}

	::selection {
		background: rgba(158, 213, 214, 0.55);
	}
</style>

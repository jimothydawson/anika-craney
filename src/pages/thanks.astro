---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Thanks | Anika Craney" description="Thanks for registering your interest with Anika Craney.">
	<div class="thanks-shell">
		<section class="thanks-card">
			<p class="eyebrow">Thanks</p>
			<h1>You&apos;re on the list</h1>
			<p>
				Anika will be in touch with details, availability, and any offers as they&apos;re
				confirmed.
			</p>
			<a class="thanks-link" href="/">Return to homepage</a>
		</section>
	</div>
</Layout>

<style>
	.thanks-shell {
		min-height: 100vh;
		display: grid;
		place-items: center;
		padding: 1.5rem;
	}

	.thanks-card {
		width: min(100%, 42rem);
		padding: clamp(1.8rem, 4vw, 3rem);
		border-radius: 1.6rem;
		border: 1px solid rgba(16, 34, 45, 0.12);
		background: rgba(250, 247, 240, 0.82);
		backdrop-filter: blur(10px);
		box-shadow: 0 24px 54px rgba(7, 18, 24, 0.12);
	}

	.eyebrow {
		margin: 0 0 0.6rem;
		color: var(--accent-deep);
		font-size: 0.78rem;
		letter-spacing: 0.26em;
		text-transform: uppercase;
	}

	h1,
	p {
		margin: 0;
	}

	h1 {
		font-family: var(--font-display);
		font-size: clamp(2.5rem, 8vw, 4.4rem);
		line-height: 0.94;
		text-transform: uppercase;
	}

	p + p,
	h1 + p {
		margin-top: 1rem;
	}

	.thanks-link {
		display: inline-flex;
		margin-top: 1.4rem;
		color: var(--accent-deep);
		text-decoration: none;
		border-bottom: 1px solid rgba(25, 85, 102, 0.22);
	}

	.thanks-link:hover {
		border-color: rgba(25, 85, 102, 0.5);
	}
</style>
